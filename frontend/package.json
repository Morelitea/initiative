{
  "name": "initiative-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:capacitor": "tsc -b && cross-env CAPACITOR_BUILD=true vite build",
    "cap:android": "pnpm build:capacitor && npx cap sync android && npx cap run android",
    "cap:ios": "pnpm build:capacitor && npx cap sync ios && npx cap run ios",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "generate:api": "./scripts/generate-api.sh",
    "prepare": "cd .. && husky ./frontend/.husky"
  },
  "dependencies": {
