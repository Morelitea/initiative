    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.css": "prettier --write",
    "*.{ts,tsx}": [
      "eslint --report-unused-disable-directives --max-warnings 0 --no-warn-ignored --fix",
      "prettier --write --ignore-path .prettierignore"
    ]
  }
