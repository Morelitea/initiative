# Test files (not needed in production image)
backend/app/testing/
backend/app/**/*_test.py
backend/conftest.py
backend/pytest.ini
backend/.coveragerc

# Python
**/__pycache__
**/*.pyc
backend/.venv

# Node / frontend build artifacts — installed fresh inside the image. Copying the host's
# (macOS) node_modules over the container's would corrupt the install and bloat the context.
**/node_modules
frontend/dist

**/.env
**/.env.*
!**/.env.example

# Version control
.git
.gitignore

# IDE
.vscode
.idea

# OS
**/.DS_Store
